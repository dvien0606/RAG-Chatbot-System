<!DOCTYPE html>
@{
    var landingPage = User.IsInRole("Admin") ? "/Admin/Index" : "/Index";
}
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG Chatbot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RagChatbotSystem.Presentation.styles.css" asp-append-version="true" />
    <!-- SignalR Client CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" integrity="sha512-7SRwZtqhbJvSZ7g8zxsT5789N2SgK4m1H1v0bfe5641T9wQ100L5j1Z5S0U91bUe6kXbLq3cO453Ym/F3f9NFA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <style>
        /* Modern Micro-animations & Glassmorphism alerts */
        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 1050;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .toast-notification {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-left: 4px solid var(--accent);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            border-radius: var(--radius);
            padding: 16px 20px;
            min-width: 320px;
            max-width: 400px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            transition: all 0.3s ease;
        }
        @@keyframes slideIn {
            from { transform: translateX(100%) translateY(10px); opacity: 0; }
            to { transform: translateX(0) translateY(0); opacity: 1; }
        }
        .toast-notification.hide {
            transform: translateX(100%);
            opacity: 0;
            margin-bottom: -60px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="@landingPage">
                    <span class="brand-mark">R</span>
                    <span class="brand-text">RAG Chatbot</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Index">Admin Dashboard</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Index">Workspace</a>
                                </li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="wallet-badge d-flex align-items-center gap-2">
                                <span class="user-status-dot"></span>
                                <div class="text-start lh-sm">
                                    <div class="fw-bold small text-dark">@User.Identity.Name</div>
                                    <div class="text-muted small text-uppercase" style="font-size: 0.72rem;">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                </div>
                            </div>
                            <form asp-page="/Account/Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="btn btn-primary btn-sm px-3">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container footer-content">
            <div class="footer-brand">
                <span class="brand-mark brand-mark-sm">R</span>
                <span style="font-size: 0.9rem;">&copy; 2026 RAG Chatbot System</span>
            </div>
            
            <div class="footer-links">
                <a href="#" class="footer-link">Tài liệu</a>
                <a href="#" class="footer-link">Bảo mật</a>
                <a href="#" class="footer-link">Điều khoản</a>
                <div class="footer-status">
                    <span class="footer-status-dot"></span>
                    <span>Hệ thống Hoạt động tốt</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Notification Container for SignalR -->
    <div id="toastContainer" class="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Real-time SignalR Global Notification Script -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Establish global notification connection if authenticated
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <text>
                const notifConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/notification")
                    .withAutomaticReconnect()
                    .build();

                notifConnection.on("ReceiveNotification", function (message) {
                    showToastNotification(message);
                });

                notifConnection.start().catch(err => console.error("Error connecting to NotificationHub:", err.toString()));
                </text>
            }

            window.showToastNotification = function(message, duration = 5000) {
                const container = document.getElementById("toastContainer");
                if (!container) return;

                const notif = document.createElement("div");
                notif.className = "toast-notification";
                notif.innerHTML = `
                    <div style="flex: 1;">
                        <div style="font-weight: 600; font-size: 0.88rem; color: #1e293b; margin-bottom: 2px;">Thông báo hệ thống</div>
                        <div style="font-size: 0.84rem; color: #64748b; line-height: 1.4;">${message}</div>
                    </div>
                    <button type="button" style="background:none; border:none; color:#cbd5e1; font-size:1.1rem; padding:0; line-height:1;" onclick="this.parentElement.remove()">&times;</button>
                `;

                container.appendChild(notif);

                setTimeout(() => {
                    notif.classList.add("hide");
                    setTimeout(() => notif.remove(), 300);
                }, duration);
            };
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
