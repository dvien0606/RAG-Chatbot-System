@page "{documentId:Guid}"
@model RagChatbotSystem.Presentation.Pages.Documents.PreviewModel
@{
    ViewData["Title"] = "Xem trước tài liệu";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <p class="eyebrow text-uppercase small text-secondary fw-bold" style="letter-spacing: 1px;">Xem Trước Tài Liệu</p>
            <h2 class="fw-bold text-dark">@Model.Preview.FileName</h2>
            <p class="text-muted mb-0">
                Môn học: <strong>@Model.Preview.DatasetName</strong> &bull; Định dạng: @Model.Preview.FileType.ToUpper() &bull; Dung lượng: @Math.Ceiling(Model.Preview.FileSize / 1024.0) KB &bull; Trạng thái: 
                <span class="badge @(Model.Preview.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "bg-success" : "bg-warning text-dark")">@Model.Preview.Status</span>
            </p>
        </div>
        <a asp-page="/Index" asp-route-datasetId="@Model.Preview.DatasetId" class="btn btn-outline-secondary">
            Quay lại
        </a>
    </div>

    @if (!Model.Preview.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-warning border-0 shadow-sm" style="border-radius: var(--radius);">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Tài liệu này vẫn chưa được xử lý xong. Trạng thái hiện tại: <strong>@Model.Preview.Status</strong>.
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h4 class="fw-bold m-0 text-dark">Các Phân Đoạn Đã Vector Hóa (Indexed Chunks)</h4>
            <p class="text-muted small m-0 mt-1">Đã trích xuất được @Model.Preview.Chunks.Count phân đoạn (chunks) từ tài liệu này.</p>
        </div>
        <div class="card-body px-4 pb-4">
            @if (Model.Preview.Chunks.Count == 0)
            {
                <p class="text-muted">Chưa có phân đoạn nào có sẵn cho tài liệu này.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var chunk in Model.Preview.Chunks)
                    {
                        <div class="p-3 border" style="border-radius: 10px; background: var(--surface-muted);">
                            <div class="d-flex justify-content-between gap-3 mb-2">
                                <strong class="text-primary">Phân đoạn #@chunk.ChunkIndex</strong>
                                <span class="text-muted small">Trang @chunk.PageNumber</span>
                            </div>
                            <pre style="white-space: pre-wrap; color: var(--ink); margin: 0; font-family: inherit; font-size: 0.9rem; line-height: 1.6;">@chunk.Content</pre>
                            @if (!string.IsNullOrWhiteSpace(chunk.MetadataJson))
                            {
                                <details class="mt-2">
                                    <summary class="text-muted small" style="cursor: pointer;">Chi tiết Metadata</summary>
                                    <code class="d-block p-2 bg-light border mt-1" style="font-size: 0.8rem; border-radius: var(--radius-sm);">@chunk.MetadataJson</code>
                                </details>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
