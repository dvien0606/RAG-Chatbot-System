@page
@model RagChatbotSystem.Presentation.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="auth-container d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 200px); padding-block: 40px;">
    <div class="auth-card" style="animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
        <div class="auth-title text-center mb-4">
            <span class="brand-mark mb-3" style="width: 48px; height: 48px; font-size: 1.25rem;">R</span>
            <h1 class="h3 fw-bold text-dark">Đổi mật khẩu</h1>
            <p class="text-muted" style="font-size: 0.9rem;">Vui lòng cập nhật mật khẩu của bạn để bảo mật tài khoản.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-4 shadow-sm" role="alert" style="border-radius: var(--radius); font-size: 0.88rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post" class="auth-form d-flex flex-column gap-3">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="CurrentPassword" class="form-label mb-1 fw-semibold text-secondary" style="font-size: 0.85rem;">Mật khẩu hiện tại</label>
                <input type="password" asp-for="CurrentPassword" placeholder="Nhập mật khẩu hiện tại" required 
                       class="form-control px-3 py-2" style="border-radius: var(--radius); font-size: 0.9rem;" />
            </div>

            <div>
                <label asp-for="NewPassword" class="form-label mb-1 fw-semibold text-secondary" style="font-size: 0.85rem;">Mật khẩu mới</label>
                <input type="password" asp-for="NewPassword" placeholder="Nhập mật khẩu mới (tối thiểu 8 ký tự)" required 
                       class="form-control px-3 py-2" style="border-radius: var(--radius); font-size: 0.9rem;" />
            </div>

            <div>
                <label asp-for="ConfirmNewPassword" class="form-label mb-1 fw-semibold text-secondary" style="font-size: 0.85rem;">Xác nhận mật khẩu mới</label>
                <input type="password" asp-for="ConfirmNewPassword" placeholder="Xác nhận mật khẩu mới" required 
                       class="form-control px-3 py-2" style="border-radius: var(--radius); font-size: 0.9rem;" />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 mt-2 fw-bold" style="border-radius: var(--radius); transition: all 0.2s;">
                Cập nhật mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
