@page
@model RagChatbotSystem.Presentation.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="auth-container d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 200px); padding-block: 40px;">
    <div class="auth-card text-center" style="animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; max-width: 480px;">
        <div style="font-size: 4rem; color: var(--danger); margin-bottom: 20px;">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h1 class="h3 fw-bold text-dark mb-3">Từ chối truy cập</h1>
        <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
            Bạn không có quyền truy cập vào trang này. Vui lòng liên hệ với Quản trị viên hệ thống nếu bạn nghĩ đây là một sự nhầm lẫn.
        </p>
        <div class="d-flex flex-column gap-2">
            <a asp-page="/Index" class="btn btn-primary fw-semibold py-2" style="border-radius: var(--radius);">
                Quay lại Trang chủ
            </a>
            <a asp-page="/Account/Login" class="btn btn-outline-secondary fw-semibold py-2" style="border-radius: var(--radius);">
                Đăng nhập với tài khoản khác
            </a>
        </div>
    </div>
</div>
