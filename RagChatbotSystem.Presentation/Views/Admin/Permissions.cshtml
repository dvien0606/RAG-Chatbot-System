@{
    ViewData["Title"] = "Manage Subject Permissions";
    var dataset = ViewBag.Dataset as RagChatbotSystem.Business.DTOs.DatasetDto;
    var permittedUsers = ViewBag.PermittedUsers as IReadOnlyList<RagChatbotSystem.Business.DTOs.UserDto> ?? new List<RagChatbotSystem.Business.DTOs.UserDto>();
    var availableUsers = ViewBag.AvailableUsers as IReadOnlyList<RagChatbotSystem.Business.DTOs.UserDto> ?? new List<RagChatbotSystem.Business.DTOs.UserDto>();
}

<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">Manage Subject Permissions</h2>
            <p class="text-muted m-0 mt-1">Grant or revoke access to the subject: <strong>@dataset?.Name</strong></p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to Dashboard
        </a>
    </div>

    <div class="row g-4">
        <!-- Col: Grant Access -->
        <div class="col-md-5">
            <div class="card border-0 h-100" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold m-0" style="color: var(--ink);">Grant New Permission</h5>
                    <p class="text-muted small m-0 mt-1">Select a student to grant query access to this subject.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (dataset?.IsPublic == true)
                    {
                        <div class="alert alert-warning mb-3">
                            <strong>Note:</strong> This subject is public. All users can query this subject without explicit permissions.
                        </div>
                    }

                    <form asp-action="GrantPermission" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@dataset?.DatasetId" />

                        <div class="mb-4">
                            <label for="userId" class="form-label mb-2">Select user</label>
                            <select id="userId" name="userId" required @(dataset?.IsPublic == true || !availableUsers.Any() ? "disabled" : "")>
                                @if (!availableUsers.Any())
                                {
                                    <option value="">No other users available</option>
                                }
                                else
                                {
                                    <option value="">-- Choose a user --</option>
                                    foreach (var u in availableUsers)
                                    {
                                        <option value="@u.UserId">@u.FullName (@u.Email) - @u.Role</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100" @(dataset?.IsPublic == true || !availableUsers.Any() ? "disabled" : "")>
                            Grant Permission
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Col: Permitted Users List -->
        <div class="col-md-7">
            <div class="card border-0 h-100" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold m-0" style="color: var(--ink);">Users with Access</h5>
                    <p class="text-muted small m-0 mt-1">Below are the users currently permitted to query this private subject.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" style="color: var(--ink);">
                            <thead>
                                <tr style="border-bottom: 2px solid var(--line); color: var(--muted); font-size: 0.85rem; text-transform: uppercase;">
                                    <th class="py-3">User</th>
                                    <th class="py-3">Role</th>
                                    <th class="py-3 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!permittedUsers.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">No explicit permissions granted yet.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var u in permittedUsers)
                                    {
                                        <tr style="border-bottom: 1px solid var(--line);">
                                            <td class="py-3">
                                                <div class="fw-bold" style="color: var(--ink);">@u.FullName</div>
                                                <div class="text-muted small" style="font-size: 0.8rem;">@u.Email</div>
                                            </td>
                                            <td class="py-3">
                                                <span class="status-pill">@u.Role</span>
                                            </td>
                                            <td class="py-3 text-end">
                                                <form asp-action="RevokePermission" method="post" style="display:inline;" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="datasetId" value="@dataset?.DatasetId" />
                                                    <input type="hidden" name="userId" value="@u.UserId" />
                                                    <button type="submit" class="btn btn-danger btn-sm" style="border-radius: 6px; font-weight: 600;" onclick="return confirm('Are you sure you want to revoke this permission?')">
                                                        Revoke
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
