@{
    ViewData["Title"] = "Login";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-title">
            <span class="brand-mark">R</span>
            <h1>Sign in to RAG Chatbot</h1>
            <p>Access your knowledge workspace and document-grounded chat sessions.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-4">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-warning mb-4">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-4">
                <div asp-validation-summary="All" class="small list-unstyled m-0 fw-bold"></div>
            </div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div>
                <label for="email" class="form-label mb-2">Username or email</label>
                <input type="text" id="email" name="email" placeholder="Enter your username or email" required />
            </div>

            <div>
                <label for="password" class="form-label mb-2">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign in</button>

            <div class="text-center mt-3">
                <span class="text-muted small">Accounts are provided by Admin via email.</span>
            </div>
        </form>
    </div>
</div>
